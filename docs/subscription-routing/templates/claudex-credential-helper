#!/bin/sh

set -eu

helper_dir=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)
script_path="$helper_dir/claudex-credential-helper.ps1"
powershell='/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe'

if [ ! -x "$powershell" ]; then
	printf '%s\n' 'Windows PowerShell is unavailable' >&2
	exit 1
fi

exec "$powershell" \
	-NoLogo \
	-NoProfile \
	-NonInteractive \
	-ExecutionPolicy Bypass \
	-File "$(/usr/bin/wslpath -w "$script_path")" \
	"$@"
